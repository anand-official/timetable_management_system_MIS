DATABASE_URL="file:./dev.db"
ACCESS_CODE="AKJHA"
AUTH_ENABLED="false"
AUTH_SESSION_SECRET="replace-with-a-long-random-secret"

# Local development:
# - Keep DATABASE_URL on SQLite.
# - AUTH_ENABLED can stay false while development auth is disabled.
#
# Vercel production:
# - Set DATABASE_URL to your pooled Postgres connection string.
# - Set DIRECT_DATABASE_URL to a direct non-pooled connection string for Prisma CLI commands.
# - Set AUTH_SESSION_SECRET to a long random value separate from ACCESS_CODE.
# - If your Vercel database integration provides POSTGRES_PRISMA_URL and
#   POSTGRES_URL_NON_POOLING instead, the app can use those automatically.
#
# Hosted Postgres examples for Vercel production:
# DATABASE_URL="postgresql://user:password@host:5432/dbname"
# DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname"
# POSTGRES_PRISMA_URL="postgresql://user:password@host-pooler:5432/dbname?pgbouncer=true&connect_timeout=15"
# POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/dbname"
