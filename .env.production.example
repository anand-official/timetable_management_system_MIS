ACCESS_CODE="AKJHA"
AUTH_ENABLED="true"

# Required on Vercel:
# Use your pooled Postgres runtime URL here.
DATABASE_URL="postgresql://user:password@host-pooler:5432/timetable?pgbouncer=true&connect_timeout=15"

# Recommended for Prisma CLI commands such as migrations and db push:
# Use the direct non-pooled Postgres URL here.
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/timetable"

# Optional Vercel/Marketplace aliases.
# If your provider sets these instead of DATABASE_URL / DIRECT_DATABASE_URL,
# the app and Prisma wrapper will still resolve them automatically.
# POSTGRES_PRISMA_URL="postgresql://user:password@host-pooler:5432/timetable?pgbouncer=true&connect_timeout=15"
# POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/timetable"
